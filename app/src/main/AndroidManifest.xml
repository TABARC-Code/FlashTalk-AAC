<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        No storage or media permission is declared: custom card photos are
        picked via the system photo/document chooser (ActivityResultContracts
        .GetContent), which hands back a content:// Uri without needing
        READ_EXTERNAL_STORAGE / READ_MEDIA_IMAGES on any supported API level.
        No INTERNET permission either — this app is offline-first by design
        (CLAUDE.md invariant 2), so it must never be able to ask for it.
    -->

    <application
        android:name=".FlashTalkApplication"
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:roundIcon="@drawable/ic_launcher_round"
        android:label="@string/app_name"
        android:theme="@style/Theme.FlashTalkAAC"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:supportsRtl="true">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.CategoryActivity"
            android:exported="false"
            android:parentActivityName=".ui.MainActivity" />

        <activity
            android:name=".ui.CustomCardActivity"
            android:exported="false"
            android:label="@string/custom_card_title"
            android:parentActivityName=".ui.CategoryActivity" />

        <activity
            android:name=".ui.SettingsActivity"
            android:exported="false"
            android:label="@string/action_settings"
            android:parentActivityName=".ui.MainActivity" />

        <activity
            android:name=".ui.ProfileActivity"
            android:exported="false"
            android:label="@string/action_profiles"
            android:parentActivityName=".ui.MainActivity" />

        <activity
            android:name=".ui.ImportSetActivity"
            android:exported="false"
            android:label="@string/import_title"
            android:parentActivityName=".ui.MainActivity" />

        <!--
            The widget host (the launcher, a separate app) needs to start
            this directly via an explicit Intent built from
            needs_widget_info.xml's android:configure — it has to be
            exported for that cross-app launch to succeed.
        -->
        <activity
            android:name=".ui.WidgetConfigActivity"
            android:exported="true"
            android:label="@string/widget_config_title">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>

        <!--
            AppWidgetManager/the launcher deliver widget lifecycle broadcasts
            from outside this app's process, so this one genuinely needs
            exported="true" — unlike WidgetTapReceiver below, which is only
            ever triggered via a PendingIntent this app itself constructed.
        -->
        <receiver
            android:name=".widget.NeedsWidgetProvider"
            android:exported="true"
            android:label="@string/widget_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/needs_widget_info" />
        </receiver>

        <receiver
            android:name=".widget.WidgetTapReceiver"
            android:exported="false" />

        <service
            android:name=".widget.NeedsWidgetRemoteViewsService"
            android:exported="false"
            android:permission="android.permission.BIND_REMOTEVIEWS" />

    </application>

</manifest>
