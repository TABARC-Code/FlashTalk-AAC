{
  "expo": {
    "name": "FlashTalk AAC",
    "slug": "flashtalk-aac",
    "version": "1.0.0",
    "orientation": "default",
    "userInterfaceStyle": "light",
    "scheme": "flashtalk-aac",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tabarccode.flashtalkaac"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1E3A5F"
      },
      "package": "com.tabarccode.flashtalkaac"
    },
    "web": {
      "bundler": "metro"
    }
  }
}
